# =========================================================================
# Radar I+D · I+D Hub — environment variables
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# =========================================================================

# ----- Supabase -----
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Public "anon" / publishable key. Safe to expose in the browser: RLS protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# ----- Gemini (Google AI Studio — free tier) -----
# Get a free key: https://aistudio.google.com/app/apikey
# Server-only: this key is NEVER bundled into client code.
GEMINI_API_KEY=your-gemini-api-key
# Optional. If unset, the app uses "gemini-3.1-flash-lite" (free, fast ~2s, stable).
# Pin a versioned model — avoid the "-latest" alias (it shifts versions without notice).
# Audited alternatives (free tier): gemini-2.5-flash-lite, gemini-2.5-flash.
# Re-run the audit anytime with: npm run audit:ai
GEMINI_MODEL=gemini-3.1-flash-lite

# ----- Email notifications (Resend) -----
# Server-only. Create a key at https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
# Sender address. For production, verify the doinglobal.com domain in Resend and
# use it here. In dev you can use Resend's shared sender (default if unset):
# "Radar I+D <onboarding@resend.dev>".
EMAIL_FROM=Radar I+D <radar@doinglobal.com>

# Service-role key — Dashboard → Project Settings → API → service_role.
# SERVER-ONLY: bypasses RLS to read recipients and write notifications.
# NEVER expose this in client code or commit the real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL used to build links inside emails (no trailing slash).
# Dev: http://localhost:3000 — Prod: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared secret that protects the weekly-digest cron endpoint. Vercel Cron sends
# it automatically as "Authorization: Bearer <CRON_SECRET>". Use a long random string.
CRON_SECRET=your-long-random-cron-secret
