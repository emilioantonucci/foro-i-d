# =========================================================================
# Radar I+D · I+D Hub — environment variables
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# =========================================================================

# ----- Supabase -----
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Public "anon" / publishable key. Safe to expose in the browser: RLS protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# ----- Gemini (Google AI Studio — free tier) -----
# Get a free key: https://aistudio.google.com/app/apikey
# Server-only: this key is NEVER bundled into client code.
GEMINI_API_KEY=your-gemini-api-key
# Optional. If unset, the app uses "gemini-3.1-flash-lite" (free, fast ~2s, stable).
# Pin a versioned model — avoid the "-latest" alias (it shifts versions without notice).
# Audited alternatives (free tier): gemini-2.5-flash-lite, gemini-2.5-flash.
# Re-run the audit anytime with: npm run audit:ai
GEMINI_MODEL=gemini-3.1-flash-lite
