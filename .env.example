# =========================================================================
# Radar I+D · I+D Hub — environment variables
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# =========================================================================

# ----- Supabase -----
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Public "anon" / publishable key. Safe to expose in the browser: RLS protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# ----- Gemini (Google AI Studio — free tier) -----
# Get a free key: https://aistudio.google.com/app/apikey
# Server-only: this key is NEVER bundled into client code.
GEMINI_API_KEY=your-gemini-api-key
# Optional. If unset, the app uses "gemini-flash-latest".
# Other options: gemini-flash-latest, gemini-2.5-flash, gemini-2.0-flash
GEMINI_MODEL=gemini-flash-latest
